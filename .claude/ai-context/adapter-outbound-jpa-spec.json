{
  "_memo": "feature 단위가 key, jpaEntity/table/repository/adapter/ports가 value",
  "_pk_convention": "JPA 엔티티는 UUID 타입의 @Id를 사용하며 @GeneratedValue 사용 금지. PK는 UuidGenerateService를 통해 애플리케이션에서 생성. 예외 시 @BypassPrimaryKeyConvention 사용",
  "systemphase": {
    "jpaEntity": "SystemPhaseJpaEntity",
    "table": "system_phase",
    "repository": "SystemPhaseJpaRepository",
    "adapter": "SystemPhaseJpaAdapter",
    "ports": ["LoadSystemPhasePort", "SaveSystemPhasePort"],
    "_pk_bypass_reason": "싱글톤 엔티티: 시스템당 단일 레코드만 존재하며 고정된 PK 사용"
  },
  "application": {
    "jpaEntity": "ApplicationJpaEntity",
    "table": "applications",
    "repository": "ApplicationJpaRepository",
    "adapter": "ApplicationJpaAdapter",
    "ports": ["LoadApplicationPort", "SaveApplicationPort"],
    "_pk_type": "UUID (UuidGenerateService 사용)"
  },
  "email": {
    "adapter": "MockEmailAdapter",
    "ports": ["SendEmailPort"],
    "_memo": "이메일 발송 어댑터. 현재 Mock 구현으로 로그만 출력. 추후 실제 SMTP/SES로 교체 예정."
  },
  "task": {
    "jpaEntity": "TaskJpaEntity",
    "table": "tasks",
    "repository": "TaskJpaRepository",
    "adapter": "TaskJpaAdapter",
    "ports": ["LoadTaskPort", "SaveTaskPort"],
    "_pk_type": "UUID (UuidGenerateService 사용)",
    "_indexes": ["idx_tasks_work_id (unique)", "idx_tasks_assignee_status"]
  },
  "dictionary": {
    "jpaEntity": "DictionaryJpaEntity",
    "table": "dictionary_entries",
    "repository": "DictionaryJpaRepository",
    "adapter": "DictionaryJpaAdapter",
    "ports": ["LoadDictionaryPort"],
    "_pk_type": "UUID",
    "_memo": "사전 항목. koreanTermLower, englishTermLower 컬럼으로 인덱스 최적화된 검색 지원",
    "_indexes": ["idx_dictionary_korean_lower", "idx_dictionary_english_lower"]
  }
}
